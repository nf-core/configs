params {
    config_profile_description = 'DEPRECATED: Super Computing Wales. This config is unmaintained! ' +
        'It will be removed from nf-core/configs in a year from 28/04/2026 if no new maintainer is found.' +
        'If you use this config, please consider becoming a maintainer, or notify your sysadmin.'
    config_profile_contact     = '<no maintainer>'
    config_profile_url         = 'https://supercomputing.wales/'
}
singularity {
    enabled    = true
    autoMounts = true
}
executor {
    name      = 'slurm'
    queueSize = 10
    queue     = 'htc'
}
params {
    max_memory = 384.GB
    max_cpus   = 20
    max_time   = 72.h
}
process {
    resourceLimits = [
        memory: 384.GB,
        cpus: 20,
        time: 72.h
    ]
    beforeScript = 'module load singularity-ce/3.11.4'
}
