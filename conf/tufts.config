//Profile config names for nf-core/configs
params {
    config_profile_description    = 'The Tufts University HPC cluster profile provided by nf-core/configs.'
    config_profile_contact        = 'Yucheng Zhang'
    config_profile_contact_github = '@zhan4429'
    config_profile_contact_email  = 'Yucheng.Zhang@tufts.edu'
    config_profile_url            = 'https://it.tufts.edu/high-performance-computing'
}

params {
    max_cpus      = 64
    memory        = 500.GB
    max_time      = 168.h
    partition     = 'batch'
    gpu_partition = 'gpu'
    gpu_gres      = '--gres=gpu:1'
    igenomes_base = '/cluster/tufts/biocontainers/datasets/igenomes/'

    // By default, remove work/ on successful completion. Disable for debugging with: --disable_cleanup true
    disable_cleanup = false
}

// Default: CPU jobs use batch partition; GPU-labeled jobs use gpu partition
process {
    resourceLimits = [
        cpus  : params.max_cpus,
        memory: params.memory,
        time  : params.max_time
    ]
    executor = 'slurm'
    queue    = params.partition

    // GPU jobs use gpu partition (e.g., Parabricks STAR)
    withLabel: 'process_gpu' {
        queue          = params.gpu_partition
        clusterOptions = params.gpu_gres
    }
}

executor {
    queueSize         = 16
    pollInterval      = '1 min'
    queueStatInterval = '5 min'
    submitRateLimit   = '10 sec'
}

// Set $NXF_SINGULARITY_CACHEDIR in your ~/.bashrc
// to stop downloading the same image for every run
singularity {
    enabled    = true
    autoMounts = true
}

// Enable the tracing feature and allow to overwrite existing trace files
trace {
    enabled   = true
    overwrite = true
}

// Enable the report feature and allow to overwrite existing report files
report {
    enabled   = true
    overwrite = true
}

// Enable the timeline feature and allow to overwrite existing timeline files
timeline {
    enabled   = true
    overwrite = true
}

// Enable the dag feature and allow to overwrite existing dag files
dag {
    enabled   = true
    overwrite = true
}

// On a successful completion of a Nextflow run, automatically delete all intermediate files stored in the work/ directory
cleanup = !params.disable_cleanup
