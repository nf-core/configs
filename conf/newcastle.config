params {
    config_profile_description = 'Newcastle comet HPC cluster profile'
    config_profile_contact = 'Chris Wyatt (@chriswyatt1)'
    config_profile_url = ''
    account = null
}

executor {
    name = 'slurm'
}

process {
    scratch = true
    errorStrategy = { task.exitStatus in [137, 140] ? 'retry' : 'finish' }
    queue   = 'defq'                    // maps to `#SBATCH -p defq`
    clusterOptions = '--account=DESIM'  // maps to `#SBATCH -A DESIM`

    clusterOptions = {
        def opts = []
        if (params.account) {
          opts << "--account=${params.account}"
        }
        return opts.join(' ')
      }
}

singularity {
    enabled = true
    pullTimeout = '2 h'
    autoMounts = true
}
